# Server
NODE_ENV=development
BACKEND_PORT=4000

# Database
POSTGRES_USER=annie
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=annie_db
DATABASE_URL=postgresql://annie:change_this_password_in_production@postgres:5432/annie_db?schema=public

# Redis
REDIS_URL=redis://redis:6379

# MeiliSearch
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change_this_key_in_production
MEILI_MASTER_KEY=change_this_key_in_production

# JWT
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# Annie AI Service (根据实际情况配置)
ANNIE_API_URL=http://localhost:8000
ANNIE_API_KEY=your_annie_api_key

# CORS
CORS_ORIGIN=http://localhost:3000
