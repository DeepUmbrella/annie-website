# Local Docker Compose development
# Root `.env` is used by docker-compose by default.

NODE_ENV=development
BACKEND_PORT=3001

POSTGRES_USER=annie
POSTGRES_PASSWORD=annie_secure_pass
POSTGRES_DB=annie_db
DATABASE_URL=postgresql://annie:annie_secure_pass@192.168.1.16:5432/annie_db?schema=public


# Redis
REDIS_PASSWORD=redis_password

# MeiliSearch
MEILISEARCH_MASTER_KEY=your_meilisearch_key


# Database
POSTGRES_USER=annie
POSTGRES_PASSWORD=annie_secure_pass
POSTGRES_DB=annie_db

# Redis
REDIS_URL=redis://192.168.1.16:6379

# MeiliSearch
MEILISEARCH_URL=http://192.168.1.16:7700
MEILISEARCH_MASTER_KEY=your_meilisearch_key
MEILI_MASTER_KEY=your_meilisearch_key

# JWT
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# Annie AI Service (根据实际情况配置)
ANNIE_API_URL=http://localhost:8000
ANNIE_API_KEY=your_annie_api_key

# CORS
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
