# Local host development
# Use this file when you run services directly on your machine.

NODE_ENV=development
PORT=3001
BACKEND_PORT=3001

# Database
POSTGRES_USER=annie
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=annie_db
DATABASE_URL=postgresql://annie:change_this_password_in_production@localhost:5432/annie_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# MeiliSearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=change_this_key_in_production
MEILI_MASTER_KEY=change_this_key_in_production

# JWT
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# Annie AI Service
ANNIE_API_URL=http://localhost:8000
ANNIE_API_KEY=your_annie_api_key

# CORS
CORS_ORIGIN=http://localhost:3000
